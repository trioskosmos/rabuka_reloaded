use rabuka_engine::game_state::{GameState, Phase, TurnPhase};
use rabuka_engine::player::Player;
use rabuka_engine::turn::TurnEngine;
use crate::qa_individual::common::{load_all_cards, create_card_database, get_card_id, setup_player_with_hand, setup_player_with_energy, setup_player_with_deck};

#[test]
fn test_q041_cheer_card_timing() {
    // Q041: When are cards revealed by cheer check placed in the waitroom?
    // Answer: In the live win/loss determination phase, after the winning player places the live card
    // in the success live card zone — the cheer cards are placed with the remaining cards.

    let cards = load_all_cards();
    let card_database = create_card_database(cards.clone());

    let live_card = cards.iter()
        .find(|c| c.is_live() && get_card_id(c, &card_database) != 0)
        .expect("Need a live card");
    let live_id = get_card_id(live_card, &card_database);

    let member_card = cards.iter()
        .filter(|c| c.is_member() && c.blade > 0)
        .filter(|c| c.cost.unwrap_or(0) <= 2)
        .filter(|c| get_card_id(c, &card_database) != 0)
        .next()
        .expect("Need member card with blades");
    let member_id = get_card_id(member_card, &card_database);

    let mut player1 = Player::new("player1".to_string(), "Player 1".to_string(), true);
    let mut player2 = Player::new("player2".to_string(), "Player 2".to_string(), false);

    setup_player_with_hand(&mut player1, vec![member_id, live_id]);
    let energy_card_ids: Vec<i16> = cards.iter()
        .filter(|c| c.is_energy())
        .filter(|c| get_card_id(c, &card_database) != 0)
        .map(|c| get_card_id(c, &card_database))
        .take(15)
        .collect();
    setup_player_with_energy(&mut player1, energy_card_ids.clone());
    setup_player_with_energy(&mut player2, energy_card_ids.clone());

    let deck_card_ids: Vec<i16> = cards.iter()
        .filter(|c| get_card_id(c, &card_database) != 0)
        .map(|c| get_card_id(c, &card_database))
        .take(30)
        .collect();
    setup_player_with_deck(&mut player1, deck_card_ids.clone());
    setup_player_with_deck(&mut player2, deck_card_ids);

    let mut game_state = GameState::new(player1, player2, card_database.clone());
    game_state.current_phase = Phase::Main;
    game_state.turn_number = 1;
    game_state.current_turn_phase = TurnPhase::FirstAttackerNormal;

    let waitroom_before = game_state.player1.waitroom.cards.len();

    // Play member to stage
    TurnEngine::execute_main_phase_action(
        &mut game_state, &rabuka_engine::game_setup::ActionType::PlayMemberToStage,
        Some(member_id), None,
        Some(rabuka_engine::zones::MemberArea::Center), Some(false),
    ).expect("Member should play");

    // Advance to LiveCardSet -> Performance
    TurnEngine::advance_phase(&mut game_state);
    TurnEngine::advance_phase(&mut game_state);
    TurnEngine::execute_main_phase_action(
        &mut game_state, &rabuka_engine::game_setup::ActionType::SetLiveCard,
        Some(live_id), None, None, None,
    ).expect("Set live card");
    TurnEngine::execute_main_phase_action(
        &mut game_state, &rabuka_engine::game_setup::ActionType::Pass,
        None, None, None, None,
    ).expect("P1 pass");
    TurnEngine::execute_main_phase_action(
        &mut game_state, &rabuka_engine::game_setup::ActionType::Pass,
        None, None, None, None,
    ).expect("P2 pass");

    // Record resolution zone state before live
    let res_before = game_state.resolution_zone.cards.len();

    // Perform live — cheer cards go to resolution zone, then cleared to waitroom
    TurnEngine::player_perform_live(
        &mut game_state.player1,
        &mut game_state.resolution_zone,
        &game_state.player1.id,
        &card_database,
    );

    let res_after = game_state.resolution_zone.cards.len();
    let waitroom_after = game_state.player1.waitroom.cards.len();

    // Resolution zone must be empty after live (cards moved to waitroom or cleared)
    assert_eq!(res_after, 0,
        "Resolution zone should be empty after live (cards moved to waitroom)");

    // Waitroom likely grew (resolution zone cards + any discarded live cards)
    assert!(waitroom_after >= waitroom_before,
        "Waitroom should not lose cards during live");

    println!("Q041: Cheer card placement timing");
    println!("Resolution zone: {} -> {} (should be cleared)", res_before, res_after);
    println!("Waitroom: {} -> {}", waitroom_before, waitroom_after);
}
